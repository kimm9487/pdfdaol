# --- Python Backend Cache Files ---
__pycache__/          # 파이썬 실행 시 자동 생성되는 컴파일 폴더
*.py[cod]             # .pyc, .pyo, .pyd 파일들
*$py.class            # Jython 컴파일 파일
.pytest_cache/        # 테스트 시 생성되는 캐시
.mypy_cache/          # Mypy 정적 검사 캐시
.ruff_cache/          # Ruff 린터 캐시

